{
  "name": "Bäumer Docs",
  "short_name": "Bäumer Docs",
  "description": "Familien-Dokumentenscanner",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#FBF8F3",
  "theme_color": "#FBF8F3",
  "orientation": "portrait",
  "icons": [
    {
      "src": "data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 192 192'><rect width='192' height='192' rx='40' fill='%23E07A5F'/><text x='96' y='130' font-size='100' text-anchor='middle'>📄</text></svg>",
      "sizes": "192x192",
      "type": "image/svg+xml"
    }
  ],
  "share_target": {
    "action": "/?share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [
        {
          "name": "file",
          "accept": ["image/jpeg", "image/png", "image/heic", "application/pdf"]
        }
      ]
    }
  }
}
